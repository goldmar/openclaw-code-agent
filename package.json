{
  "name": "openclaw-code-agent",
  "version": "4.3.4",
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "main": "dist/index.js",
  "scripts": {
    "audit:prod": "pnpm audit --prod",
    "build": "esbuild index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --minify --external:@anthropic-ai/claude-agent-sdk",
    "check-plugin-security": "node scripts/check-plugin-security.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:serial": "node scripts/run-tests.mjs",
    "test:file": "node scripts/run-tests.mjs",
    "smoke:backend": "node scripts/run-tests.mjs tests/codex-harness.test.ts tests/plan-mode-e2e.test.ts tests/session-restore-service.test.ts",
    "smoke:backend-parity": "node scripts/run-tests.mjs tests/backend-contract-smoke.test.ts tests/codex-harness.test.ts tests/harness-registry.test.ts",
    "smoke:codex-worktrees": "node scripts/run-tests.mjs tests/codex-harness.test.ts tests/session-bootstrap.test.ts tests/session-restore-service.test.ts",
    "smoke:codex-live": "OPENCLAW_RUN_LIVE_CODEX_SMOKE=1 node scripts/run-tests.mjs tests/live-codex-app-server-smoke.test.ts",
    "smoke:codex-release": "OPENCLAW_RUN_LIVE_CODEX_RELEASE_SMOKE=1 node scripts/run-tests.mjs tests/live-codex-app-server-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "validate:release-metadata": "node scripts/validate-release-metadata.mjs",
    "verify": "pnpm typecheck && pnpm build && pnpm test"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "openclaw-code-agent",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.21"
    },
    "compat": {
      "pluginApi": ">=2026.4.21",
      "minGatewayVersion": "2026.4.21"
    },
    "build": {
      "openclawVersion": "2026.5.27",
      "pluginSdkVersion": "2026.5.27"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.142"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "nanoid": "^5.1.7",
    "openclaw": "2026.5.27",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "claude",
    "claude-code",
    "coding-agent",
    "codex",
    "ai",
    "anthropic",
    "agent",
    "code-generation",
    "automation",
    "cli",
    "background-process",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goldmar/openclaw-code-agent.git"
  },
  "homepage": "https://github.com/goldmar/openclaw-code-agent#readme",
  "bugs": {
    "url": "https://github.com/goldmar/openclaw-code-agent/issues"
  },
  "license": "MIT",
  "author": "Mark Goldenstein",
  "publishConfig": {
    "access": "public"
  },
  "description": "An OpenClaw plugin that orchestrates coding agent sessions as managed background processes. Launch, monitor, and control coding agents (Claude Code, Codex, and more) directly from your AI gateway.",
  "peerDependencies": {
    "openclaw": ">=2026.4.21"
  },
  "overrides": {
    "basic-ftp": "5.3.1",
    "fast-xml-builder@<1.1.7": "1.1.7",
    "ip-address@<10.1.1": "10.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "basic-ftp": "5.3.1",
      "axios@<1.15.0": ">=1.15.0",
      "fast-xml-builder@<1.1.7": "1.1.7",
      "follow-redirects@<1.16.0": "1.16.0",
      "protobufjs@>=7 <7.5.6": "7.5.6",
      "@protobufjs/utf8@<1.1.1": "1.1.1",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "fast-xml-parser@>=5.0.0 <5.7.0": ">=5.7.0",
      "@anthropic-ai/sdk@<0.93.0": "0.93.0",
      "ip-address@<10.1.1": "10.1.1",
      "fast-uri@<=3.1.1": "3.1.2",
      "qs@<6.15.2": "6.15.2",
      "hono@<4.12.18": "4.12.18"
    }
  }
}
